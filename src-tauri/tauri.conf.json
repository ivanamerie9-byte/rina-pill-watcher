{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rina Pill Watcher",
  "version": "0.1.0",
  "identifier": "com.rina.pillwatcher",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Rina Pill Watcher",
        "width": 390,
        "height": 844,
        "resizable": false,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "minSdkVersion": 26
    }
  }
}
